<script>
// === STATE ===
let scanRunning = false;
let theatreMode = false;
let scanData = null;
let logTimer = null;
const startTime = Date.now();

function ts() {
  const s = Math.floor((Date.now() - startTime) / 1000);
  const m = Math.floor(s / 60);
  const ss = s % 60;
  return `${String(m).padStart(2,'0')}:${String(ss).padStart(2,'0')}:${String(Math.floor(Math.random()*99)).padStart(2,'0')}`;
}

// === LOG ENGINE ===
function addLog(msg, type='', delay=0) {
  setTimeout(() => {
    const body = document.getElementById('console-body');
    const div = document.createElement('div');
    div.className = 'log-entry';
    div.innerHTML = `<span class="log-time">${ts()}</span><span class="log-msg ${type}">${msg}</span>`;
    body.appendChild(div);
    body.scrollTop = body.scrollHeight;
  }, delay);
}

// === TOAST SYSTEM ===
function showAlert(type, title, sub, onClick) {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = `toast toast-${type}`;
  toast.innerHTML = `
    <div class="toast-icon">${type==='critical' ? '⚠' : 'ℹ'}</div>
    <div class="toast-body">
      <div class="toast-title">${title}</div>
      <div class="toast-sub">${sub}</div>
    </div>
    <div class="toast-close" onclick="this.parentElement.remove()">✕</div>
  `;
  if (onClick) toast.addEventListener('click', onClick);
  container.appendChild(toast);
  setTimeout(() => toast.remove(), 7000);
}

// === THEATRE MODE ===
function toggleTheatre() {
  theatreMode = !theatreMode;
  const btn = document.getElementById('theatre-btn');
  btn.classList.toggle('active', theatreMode);
  btn.textContent = theatreMode ? '🎬 EXIT THEATRE' : '🎬 THEATRE MODE';
  document.body.style.setProperty('--bg-void', theatreMode ? '#000006' : '#020612');
  addLog(`[ UI ] Theatre Mode ${theatreMode ? 'ACTIVATED' : 'DEACTIVATED'}`, theatreMode ? 'success' : 'info');
}

// === SANDBOX ===
function openSandbox(url) {
  document.getElementById('sandbox-url').textContent = url;
  document.getElementById('sandbox-overlay').classList.add('open');
  addLog('[ SANDBOX ] HLS stream intercepted — sandbox initialized', 'warn');
}

function closeSandbox() {
  document.getElementById('sandbox-overlay').classList.remove('open');
}

// === STEPPER ===
function setStep(n) {
  for (let i = 1; i <= 4; i++) {
    const dot = document.getElementById(`s${i}`);
    const label = document.getElementById(`sl${i}`);
    const line = document.getElementById(`line${i}`);
    dot.classList.remove('done', 'active-step');
    label.classList.remove('done', 'active-step');
    if (line) line.classList.remove('done');
    if (i < n) {
      dot.classList.add('done');
      dot.textContent = '✓';
      label.classList.add('done');
      if (line) line.classList.add('done');
    } else if (i === n) {
      dot.classList.add('active-step');
      label.classList.add('active-step');
    }
  }
}

// === SCAN SEQUENCE ===
function startScan() {
  const url = document.getElementById('url-input').value.trim();
  if (!url) {
    showAlert('info', 'TARGET REQUIRED', 'Enter a URL to initiate forensic scan.');
    return;
  }
  if (scanRunning) return;
  scanRunning = true;

  const stepper = document.getElementById('stepper');
  stepper.classList.add('active');
  for (let i = 1; i <= 4; i++) {
    const dot = document.getElementById(`s${i}`);
    dot.textContent = `0${i}`;
    dot.classList.remove('done','active-step');
    document.getElementById(`sl${i}`).classList.remove('done','active-step');
  }

  addLog(`[ SCAN ] Target acquired: ${url}`, 'info');
  addLog('[ INIT ] Spawning stealth Chromium instance...', '', 300);
  setStep(1);

  setTimeout(() => {
    addLog('[ GATE ] Randomizing browser fingerprint', '', 0);
    addLog('[ GATE ] Injecting stealth headers', '', 400);
    setStep(2);
  }, 2500);

  setTimeout(() => {
    addLog('[ BYPASS ] Cloudflare challenge — Bypassing Gate...', 'warn');
    addLog('[ BYPASS ] TLS fingerprint spoofed ✓', '', 500);
    setStep(3);
  }, 5500);

  setTimeout(() => {
    addLog('[ JS ] Intercepting API Handshake...', 'warn');
    addLog('[ JS ] Scanning bundle for credential leaks...', '', 400);
    addLog('[ LEAK ] ⚠ Exposed API key found in main.bundle.js:847', 'critical', 800);
    setStep(4);
  }, 9000);

  setTimeout(() => {
    addLog('[ REPORT ] Compiling intelligence package...', 'info');
    addLog('[ REPORT ] Extracting full DOM snapshot...', '', 500);
  }, 12500);

  setTimeout(() => {
    addLog('[ DONE ] Scan complete — 4 modules populated', 'success');
    addLog('[ ALERT ] 2 critical exposures detected', 'critical', 300);
    completeScan(url);
  }, 15000);
}

function completeScan(url) {
  scanRunning = false;
  const stepper = document.getElementById('stepper');

  for (let i = 1; i <= 4; i++) {
    document.getElementById(`s${i}`).classList.remove('active-step');
    document.getElementById(`s${i}`).classList.add('done');
    document.getElementById(`s${i}`).textContent = '✓';
    document.getElementById(`sl${i}`).classList.add('done');
    const line = document.getElementById(`line${i}`);
    if (line) line.classList.add('done');
  }

  setTimeout(() => stepper.classList.remove('active'), 2000);

  // Stats
  document.getElementById('stat-endpoints').textContent = '23';
  document.getElementById('stat-assets').textContent = '47';
  document.getElementById('stat-streams').textContent = '3';
  document.getElementById('stat-creds').textContent = '2';

