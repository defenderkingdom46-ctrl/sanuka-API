<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Project CINEFy — Prime-X-Team</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Exo+2:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-void: #020612;
    --bg-deep: #040d1f;
    --bg-panel: rgba(6, 18, 48, 0.72);
    --bg-glass: rgba(10, 28, 70, 0.45);
    --bg-glass2: rgba(15, 38, 90, 0.3);
    --cyan: #00e5ff;
    --cyan-dim: rgba(0,229,255,0.15);
    --cyan-glow: rgba(0,229,255,0.4);
    --purple: #b44fff;
    --purple-dim: rgba(180,79,255,0.15);
    --purple-glow: rgba(180,79,255,0.4);
    --green-log: #00ff88;
    --green-dim: rgba(0,255,136,0.12);
    --amber: #ffaa00;
    --red-alert: #ff3366;
    --text-primary: #e8f4ff;
    --text-secondary: rgba(180,210,255,0.7);
    --text-muted: rgba(120,160,220,0.5);
    --border-cyan: rgba(0,229,255,0.3);
    --border-purple: rgba(180,79,255,0.3);
    --border-dim: rgba(0,229,255,0.1);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg-void);
    color: var(--text-primary);
    font-family: 'Exo 2', sans-serif;
    font-weight: 300;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* === ANIMATED BG GRID === */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    animation: gridDrift 40s linear infinite;
    pointer-events: none;
  }

  @keyframes gridDrift {
    0% { transform: translateY(0); }
    100% { transform: translateY(48px); }
  }

  body::after {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 60% 40% at 20% 50%, rgba(0,229,255,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 50% 60% at 80% 30%, rgba(180,79,255,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 40% 80% at 50% 100%, rgba(0,100,200,0.08) 0%, transparent 50%);
    pointer-events: none;
  }

  /* === LAYOUT === */
  .layout {
    position: relative; z-index: 1;
    display: grid;
    grid-template-rows: auto auto 1fr;
    grid-template-columns: 1fr 320px;
    grid-template-areas:
      "header header"
      "command command"
      "main sidebar";
    min-height: 100vh;
    gap: 0;
  }

  /* === HEADER === */
  header {
    grid-area: header;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    height: 64px;
    border-bottom: 1px solid var(--border-cyan);
    background: rgba(2,6,18,0.85);
    backdrop-filter: blur(20px);
    position: sticky; top: 0; z-index: 100;
  }

  .logo-group { display: flex; align-items: center; gap: 16px; }

  .logo-icon {
    width: 36px; height: 36px;
    border: 1.5px solid var(--cyan);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    position: relative;
    box-shadow: 0 0 12px var(--cyan-glow), inset 0 0 12px rgba(0,229,255,0.08);
    animation: logoPulse 3s ease-in-out infinite;
  }

  @keyframes logoPulse {
    0%,100% { box-shadow: 0 0 12px var(--cyan-glow), inset 0 0 12px rgba(0,229,255,0.08); }
    50% { box-shadow: 0 0 24px var(--cyan-glow), inset 0 0 20px rgba(0,229,255,0.15); }
  }

  .logo-icon svg { width: 20px; height: 20px; fill: var(--cyan); }

  .logo-text {
    font-family: 'Orbitron', monospace;
    font-size: 18px;
    font-weight: 900;
    letter-spacing: 3px;
    background: linear-gradient(90deg, var(--cyan), var(--purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .logo-sub {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 2px;
    margin-top: 2px;
  }

  .header-right { display: flex; align-items: center; gap: 20px; }

  .status-dot {
    display: flex; align-items: center; gap: 8px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--green-log);
  }

  .status-dot::before {
    content: '';
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green-log);
    box-shadow: 0 0 8px var(--green-log);
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .btn-theatre {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
    padding: 6px 14px;
    border: 1px solid var(--border-purple);
    background: var(--purple-dim);
    color: var(--purple);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }

  .btn-theatre:hover, .btn-theatre.active {
    background: rgba(180,79,255,0.3);
    box-shadow: 0 0 12px var(--purple-glow);
    border-color: var(--purple);
  }

  .version-tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 1px;
  }

  /* === COMMAND CENTER === */
  .command-zone {
    grid-area: command;
    padding: 32px 32px 24px;
    background: linear-gradient(180deg, rgba(0,229,255,0.04) 0%, transparent 100%);
    border-bottom: 1px solid var(--border-dim);
  }

  .command-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .url-bar-wrap {
    display: flex;
    gap: 12px;
    align-items: stretch;
  }

  .url-bar {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
  }

  .url-bar::before {
    content: '';
    position: absolute; inset: -1px;
    border-radius: 8px;
    background: linear-gradient(90deg, var(--cyan), var(--purple), var(--cyan));
    background-size: 200% 100%;
    z-index: 0;
    animation: borderFlow 3s linear infinite;
    opacity: 0.6;
  }

  @keyframes borderFlow {
    0% { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }

  .url-bar input {
    position: relative; z-index: 1;
    width: 100%;
    padding: 14px 20px 14px 50px;
    background: rgba(4,13,30,0.95);
    border: none;
    border-radius: 7px;
    color: var(--cyan);
    font-family: 'Share Tech Mono', monospace;
    font-size: 14px;
    letter-spacing: 0.5px;
    outline: none;
  }

  .url-bar input::placeholder { color: var(--text-muted); }

  .url-icon {
    position: absolute; left: 16px; z-index: 2;
    width: 18px; height: 18px;
    color: var(--cyan);
    opacity: 0.6;
  }

  .scan-btn {
    padding: 0 32px;
    background: linear-gradient(135deg, var(--cyan), #0099bb);
    border: none;
    border-radius: 8px;
    color: var(--bg-void);
    font-family: 'Orbitron', monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    position: relative;
    overflow: hidden;
    white-space: nowrap;
  }

  .scan-btn::before {
    content: '';
    position: absolute;
    top: -50%; left: -50%;
    width: 200%; height: 200%;
    background: linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.2) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.4s;
  }

  .scan-btn:hover::before { transform: translateX(100%); }
  .scan-btn:hover { box-shadow: 0 0 24px var(--cyan-glow); transform: translateY(-1px); }

  /* === PROGRESS STEPPER === */
  .progress-stepper {
    margin-top: 16px;
    display: none;
    gap: 0;
    align-items: center;
  }

  .progress-stepper.active { display: flex; }

  .step {
    display: flex; align-items: center; gap: 8px;
    flex: 1;
  }

  .step-dot {
    width: 28px; height: 28px; flex-shrink: 0;
    border-radius: 50%;
    border: 1.5px solid var(--border-cyan);
    background: var(--bg-deep);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    transition: all 0.3s;
    position: relative;
  }

  .step-dot.done {
    border-color: var(--green-log);
    color: var(--green-log);
    background: var(--green-dim);
    box-shadow: 0 0 10px rgba(0,255,136,0.3);
  }

  .step-dot.active-step {
    border-color: var(--cyan);
    color: var(--cyan);
    background: var(--cyan-dim);
    box-shadow: 0 0 12px var(--cyan-glow);
    animation: stepPulse 0.8s ease-in-out infinite;
  }

  @keyframes stepPulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.1)} }

  .step-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    transition: color 0.3s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .step-label.active-step { color: var(--cyan); }
  .step-label.done { color: var(--green-log); }

  .step-line {
    flex: 1;
    height: 1px;
    background: var(--border-dim);
    margin: 0 8px;
    transition: background 0.3s;
    min-width: 20px;
  }

  .step-line.done { background: var(--green-log); box-shadow: 0 0 6px rgba(0,255,136,0.4); }

  /* === MAIN CONTENT === */
  main {
    grid-area: main;
    padding: 24px 24px 24px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    overflow-y: auto;
    min-height: 0;
  }

  /* === GLASS MODULES === */
  .module {
    background: var(--bg-panel);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border-cyan);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.3s;
    position: relative;
  }

  .module::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan), var(--purple), transparent);
    opacity: 0.6;
  }

  .module:hover { border-color: rgba(0,229,255,0.5); }

  .module-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border-dim);
    background: rgba(0,229,255,0.03);
  }

  .module-title-group { display: flex; align-items: center; gap: 10px; }

  .module-icon {
    width: 32px; height: 32px;
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
  }

  .icon-cyan { background: var(--cyan-dim); border: 1px solid var(--border-cyan); }
  .icon-purple { background: var(--purple-dim); border: 1px solid var(--border-purple); }
  .icon-amber { background: rgba(255,170,0,0.12); border: 1px solid rgba(255,170,0,0.3); }
  .icon-red { background: rgba(255,51,102,0.12); border: 1px solid rgba(255,51,102,0.3); }

  .module-title {
    font-family: 'Orbitron', monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--text-primary);
    text-transform: uppercase;
  }

  .module-subtitle {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 1px;
    margin-top: 2px;
  }

  .module-badge {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 1px;
  }

  .badge-cyan { background: var(--cyan-dim); border: 1px solid var(--border-cyan); color: var(--cyan); }
  .badge-purple { background: var(--purple-dim); border: 1px solid var(--border-purple); color: var(--purple); }
  .badge-amber { background: rgba(255,170,0,0.12); border: 1px solid rgba(255,170,0,0.3); color: var(--amber); }

  .module-body { padding: 20px; }

  /* === SOURCE CODE ENGINE === */
  .code-viewer {
    background: rgba(2,6,14,0.8);
    border: 1px solid var(--border-dim);
    border-radius: 6px;
    padding: 16px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--green-log);
    line-height: 1.7;
    max-height: 220px;
    overflow-y: auto;
    position: relative;
  }

  .code-viewer::-webkit-scrollbar { width: 4px; }
  .code-viewer::-webkit-scrollbar-track { background: transparent; }
  .code-viewer::-webkit-scrollbar-thumb { background: var(--border-cyan); border-radius: 4px; }

  .code-line { display: flex; gap: 12px; }
  .line-num { color: var(--text-muted); min-width: 24px; text-align: right; user-select: none; }
  .line-content { color: var(--green-log); }
  .line-highlight { background: rgba(255,51,102,0.18); border-left: 2px solid var(--red-alert); margin: 0 -16px; padding: 0 14px; }
  .line-highlight .line-content { color: #ff8080; }

  .code-actions {
    display: flex; gap: 10px; margin-top: 14px;
  }

  .btn-action {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 1px;
    padding: 7px 16px;
    border-radius: 5px;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    border: 1px solid;
  }

  .btn-cyan {
    background: var(--cyan-dim);
    border-color: var(--border-cyan);
    color: var(--cyan);
  }

  .btn-cyan:hover {
    background: rgba(0,229,255,0.25);
    box-shadow: 0 0 12px var(--cyan-glow);
  }

  .btn-purple {
    background: var(--purple-dim);
    border-color: var(--border-purple);
    color: var(--purple);
  }

  .btn-purple:hover {
    background: rgba(180,79,255,0.25);
    box-shadow: 0 0 12px var(--purple-glow);
  }

  .btn-amber {
    background: rgba(255,170,0,0.1);
    border-color: rgba(255,170,0,0.3);
    color: var(--amber);
  }

  .btn-amber:hover { background: rgba(255,170,0,0.2); box-shadow: 0 0 12px rgba(255,170,0,0.3); }

  .btn-red {
    background: rgba(255,51,102,0.1);
    border-color: rgba(255,51,102,0.35);
    color: var(--red-alert);
  }

  .btn-red:hover { background: rgba(255,51,102,0.2); box-shadow: 0 0 12px rgba(255,51,102,0.3); }

  /* === ENDPOINT FORENSIC === */
  .endpoint-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .endpoint-card {
    background: rgba(2,6,18,0.6);
    border: 1px solid var(--border-dim);
    border-radius: 6px;
    padding: 14px;
    transition: all 0.2s;
  }

  .endpoint-card:hover { border-color: var(--border-cyan); background: var(--bg-glass); }

  .endpoint-method {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 3px;
    display: inline-block;
    margin-bottom: 8px;
  }

  .method-get { background: rgba(0,255,136,0.12); color: var(--green-log); border: 1px solid rgba(0,255,136,0.3); }
  .method-post { background: rgba(0,229,255,0.12); color: var(--cyan); border: 1px solid var(--border-cyan); }
  .method-ws { background: rgba(180,79,255,0.12); color: var(--purple); border: 1px solid var(--border-purple); }

  .endpoint-path {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--text-secondary);
    word-break: break-all;
  }

  .endpoint-meta {
    margin-top: 6px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
  }

  /* === API INTELLIGENCE === */
  .api-stream-list { display: flex; flex-direction: column; gap: 10px; }

  .stream-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    background: rgba(2,6,18,0.6);
    border: 1px solid var(--border-dim);
    border-radius: 6px;
    transition: all 0.2s;
  }

  .stream-item:hover { border-color: var(--border-cyan); }

  .stream-type-badge {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    padding: 3px 8px;
    border-radius: 3px;
    flex-shrink: 0;
    letter-spacing: 1px;
    font-weight: 700;
  }

  .type-m3u8 { background: rgba(255,51,102,0.15); color: var(--red-alert); border: 1px solid rgba(255,51,102,0.4); }
  .type-json { background: var(--cyan-dim); color: var(--cyan); border: 1px solid var(--border-cyan); }
  .type-graphql { background: var(--purple-dim); color: var(--purple); border: 1px solid var(--border-purple); }

  .stream-url {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--text-secondary);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .btn-play {
    padding: 5px 14px;
    background: rgba(255,51,102,0.15);
    border: 1px solid rgba(255,51,102,0.4);
    color: var(--red-alert);
    border-radius: 4px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
    letter-spacing: 1px;
  }

  .btn-play:hover { background: rgba(255,51,102,0.3); box-shadow: 0 0 10px rgba(255,51,102,0.3); }

  /* === ASSET VAULT === */
  .asset-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 10px;
  }

  .asset-thumb {
    aspect-ratio: 16/9;
    border-radius: 6px;
    border: 1px solid var(--border-dim);
    overflow: hidden;
    position: relative;
    cursor: pointer;
    transition: all 0.2s;
    background: var(--bg-glass2);
    display: flex; align-items: center; justify-content: center;
  }

  .asset-thumb:hover { border-color: var(--cyan); transform: scale(1.03); box-shadow: 0 0 14px var(--cyan-glow); }

  .asset-thumb img { width: 100%; height: 100%; object-fit: cover; opacity: 0.8; }

  .asset-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,229,255,0.4), transparent);
    opacity: 0;
    transition: opacity 0.2s;
    display: flex; align-items: flex-end; padding: 6px;
  }

  .asset-thumb:hover .asset-overlay { opacity: 1; }

  .asset-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    color: white;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .asset-placeholder {
    font-size: 20px;
    color: var(--text-muted);
  }

  /* === ACTION TIER === */
  .action-tier {
    display: flex;
    gap: 12px;
    padding: 20px 32px;
    border-top: 1px solid var(--border-dim);
    background: rgba(2,6,18,0.6);
    flex-wrap: wrap;
  }

  .action-tier-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 2px;
    display: flex; align-items: center;
    margin-right: 8px;
    text-transform: uppercase;
  }

  /* === SIDEBAR CONSOLE === */
  aside {
    grid-area: sidebar;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--border-cyan);
    background: rgba(2,6,18,0.75);
    backdrop-filter: blur(12px);
    overflow: hidden;
  }

  .console-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border-dim);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(0,255,136,0.03);
  }

  .console-title {
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    color: var(--green-log);
    text-transform: uppercase;
  }

  .console-pulse {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--green-log);
    box-shadow: 0 0 8px var(--green-log);
    animation: blink 1.5s ease-in-out infinite;
  }

  .console-body {
    flex: 1;
    overflow-y: auto;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .console-body::-webkit-scrollbar { width: 3px; }
  .console-body::-webkit-scrollbar-thumb { background: rgba(0,255,136,0.3); border-radius: 4px; }

  .log-entry {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    line-height: 1.6;
    display: flex;
    gap: 8px;
    opacity: 0;
    transform: translateX(-4px);
    animation: logIn 0.3s forwards;
  }

  @keyframes logIn {
    to { opacity: 1; transform: translateX(0); }
  }

  .log-time { color: var(--text-muted); flex-shrink: 0; }
  .log-msg { color: var(--green-log); }
  .log-msg.warn { color: var(--amber); }
