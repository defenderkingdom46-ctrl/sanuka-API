// === POPULATE MODULES ===
function populateSourceCode(url) {
  const viewer = document.getElementById('code-viewer');
  const hostname = new URL(url.startsWith('http') ? url : 'https://'+url).hostname;
  const lines = [
    [`1`, `<!DOCTYPE html>`, false],
    [`2`, `<html lang="en">`, false],
    [`3`, `<head>`, false],
    [`4`, `  <meta charset="UTF-8">`, false],
    [`5`, `  <title>${hostname}</title>`, false],
    [`6`, `  <link rel="stylesheet" href="https://${hostname}/static/css/main.a3f8b.css">`, false],
    [`7`, `  <script src="https://${hostname}/static/js/main.bundle.js"></script>`, false],
    [`8`, `</head>`, false],
    [`9`, `<body>`, false],
    [`10`, `  <div id="root"></div>`, false],
    [`...`, ``, false],
    [`845`, `// API Configuration`, false],
    [`846`, `const CONFIG = {`, false],
    [`847`, `  API_KEY: "sk-live-xX9mK2pQ7nR4wL8vT1aY",  // ← EXPOSED CREDENTIAL`, true],
    [`848`, `  STRIPE_PK: "pk_live_51Nx...",`, true],
    [`849`, `  BASE_URL: "https://api.${hostname}/v2"`, false],
    [`850`, `};`, false],
  ];
  viewer.innerHTML = lines.map(([n, c, crit]) =>
    `<div class="code-line ${crit ? 'line-highlight' : ''}">
      <span class="line-num">${n}</span>
      <span class="line-content">${c.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</span>
    </div>`
  ).join('');
}

function scrollToCredLine() {
  const viewer = document.getElementById('code-viewer');
  const highlighted = viewer.querySelector('.line-highlight');
  if (highlighted) highlighted.scrollIntoView({ behavior: 'smooth', block: 'center' });
  addLog('[ CRED ] Scrolling to exposed credential @ line 847', 'critical');
}

function populateEndpoints() {
  const grid = document.getElementById('endpoint-grid');
  const eps = [
    { method: 'GET', path: '/api/v2/user/profile', meta: '200 OK — 342ms' },
    { method: 'POST', path: '/api/v2/auth/token', meta: '201 — Auth endpoint' },
    { method: 'GET', path: '/api/v2/content/list?page=1', meta: '200 OK — 128ms' },
    { method: 'WS', path: 'wss://live.target.com/socket', meta: 'WebSocket — persistent' },
    { method: 'GET', path: '/.env.production', meta: '403 — Hidden path detected' },
    { method: 'POST', path: '/graphql', meta: 'GraphQL — introspection open' },
  ];
  const cls = { GET: 'method-get', POST: 'method-post', WS: 'method-ws' };
  grid.innerHTML = eps.map(e => `
    <div class="endpoint-card">
      <div class="endpoint-method ${cls[e.method] || 'method-get'}">${e.method}</div>
      <div class="endpoint-path">${e.path}</div>
      <div class="endpoint-meta">${e.meta}</div>
    </div>
  `).join('');
}

function populateStreams(url) {
  const hostname = new URL(url.startsWith('http') ? url : 'https://'+url).hostname;
  const list = document.getElementById('stream-list');
  const streams = [
    { type: 'm3u8', badge: 'type-m3u8', label: 'HLS', url: `https://cdn.${hostname}/streams/master.m3u8`, playable: true },
    { type: 'json', badge: 'type-json', label: 'JSON API', url: `https://api.${hostname}/v2/feed.json`, playable: false },
    { type: 'graphql', badge: 'type-graphql', label: 'GRAPHQL', url: `https://${hostname}/graphql?introspect=true`, playable: false },
  ];
  list.innerHTML = streams.map(s => `
    <div class="stream-item">
      <span class="stream-type-badge ${s.badge}">${s.label}</span>
      <span class="stream-url">${s.url}</span>
      ${s.playable ? `<button class="btn-play" onclick="openSandbox('${s.url}')">▶ SANDBOX</button>` : `<button class="btn-action btn-cyan" style="font-size:10px;padding:5px 12px;">📋 COPY</button>`}
    </div>
  `).join('');
}

function populateAssets() {
  const gallery = document.getElementById('asset-gallery');
  const placeholders = [
    '🖼', '🎬', '🎞', '🗂', '🖼', '🎬', '🖼', '🎞', '🗂', '🖼', '🎬', '🖼'
  ];
  const labels = ['hero-bg.jpg', 'promo-720.mp4', 'banner-1.webp', 'logo.svg', 'thumb-01.jpg', 'trailer.m3u8', 'og-image.jpg', 'poster.webp', 'icon-set.svg', 'bg-blur.jpg', 'scene-01.mp4', 'cover.jpg'];
  gallery.innerHTML = placeholders.map((ph, i) => `
    <div class="asset-thumb" title="${labels[i]}">
      <div class="asset-placeholder">${ph}</div>
      <div class="asset-overlay">
        <span class="asset-label">${labels[i]}</span>
      </div>
