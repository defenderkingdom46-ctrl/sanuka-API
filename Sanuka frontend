}

// === EXPORTS ===
function triggerZipExport() {
  addLog('[ ZIP ] Relativizing asset paths... (absolute → local)', 'info');
  addLog('[ ZIP ] Compressing source + assets into archive...', '', 400);
  setTimeout(() => {
    addLog('[ ZIP ] forensic_package.zip ready for download ✓', 'success');
    showAlert('info', 'ZIP GENERATED', 'forensic_package.zip — relativized source ready for download.');
  }, 1200);
}

function exportJSON() {
  addLog('[ JSON ] Serializing intelligence report...', 'info');
  const data = {
    timestamp: new Date().toISOString(),
    suite: 'CINEFy v4.2.0',
    team: 'Prime-X-Team',
    stats: { endpoints: 23, assets: 47, streams: 3, credentials: 2 },
    exposures: [
      { type: 'API_KEY', line: 847, file: 'main.bundle.js', severity: 'CRITICAL' },
      { type: 'STRIPE_PK', line: 848, file: 'main.bundle.js', severity: 'HIGH' }
    ]
  };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'cinefy_intelligence_report.json';
  a.click();
  addLog('[ JSON ] Intelligence report exported ✓', 'success');
}

// === CONSOLE COMMANDS ===
function handleConsoleCmd(e) {
  if (e.key !== 'Enter') return;
  const val = e.target.value.trim().toLowerCase();
  if (!val) return;
  addLog(`[ CMD ] > ${val}`, 'info');
  e.target.value = '';

  const cmds = {
    'help': () => addLog('[ HELP ] Commands: scan, clear, status, export, theatre', 'info'),
    'clear': () => { document.getElementById('console-body').innerHTML = ''; addLog('[ CONSOLE ] Cleared', 'info'); },
    'status': () => { addLog('[ STATUS ] Suite: ONLINE | Modules: 4 active', 'success'); },
    'export': exportJSON,
    'theatre': toggleTheatre,
    'scan': () => startScan(),
  };

  const fn = cmds[val];
  if (fn) fn();
  else addLog(`[ ERR ] Unknown command: "${val}" — type help`, 'warn');
}

